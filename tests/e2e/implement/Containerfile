FROM registry.access.redhat.com/ubi9/go-toolset:1.25.8-1774618347
USER root
RUN dnf install -y --allowerasing git curl podman fuse-overlayfs && dnf clean all
RUN useradd -m -u 1000 e2e && mkdir -p /home/e2e/.cache && chown -R e2e:e2e /home/e2e
USER e2e
ENV HOME=/home/e2e

# Pre-download Go module dependencies and install the ginkgo binary so the
# first test run does not need network access.
COPY --chown=e2e go.mod go.sum /tmp/harness/
RUN cd /tmp/harness \
    && go mod download \
    && go install github.com/onsi/ginkgo/v2/ginkgo

ENV PATH=/home/e2e/go/bin:$PATH
WORKDIR /workspace
